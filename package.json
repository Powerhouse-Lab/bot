{
  "name": "jellyfin-mobile-client",
  "version": "0.1.1",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:android:apk": "expo prebuild --platform android --clean && cd android && ./gradlew assembleRelease -PnewArchEnabled=false",
    "verify:react-versions": "node scripts/verify-react-versions.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "53.0.0",
    "expo-status-bar": "2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.0",
    "expo-video": "2.2.2"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "typescript": "5.8.3"
  },
  "overrides": {
    "react": "19.0.0",
    "react-native": "0.79.0",
    "@types/react": "19.0.0"
  }
}
